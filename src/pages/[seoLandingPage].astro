---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import RoomCard from '../components/ui/RoomCard.astro';
import { rooms } from '../data/rooms';


import { landingPages } from '../data/seoPages';
import { SITE } from '../utils/seoConfig';

export function getStaticPaths() {

  return landingPages.map(page => ({
    params: { seoLandingPage: page.slug },
    props: { ...page },
  }));
}

const { title, heading, description, body } = Astro.props;
---

<Layout title={`${title} | Hotel Iubit`} description={description}>
  <div class="relative bg-dark text-white py-24 text-center overflow-hidden">
    <!-- Image with alt tag for SEO -->
    <div class="absolute inset-0 z-0">
      <img src="/hero/hotel-IUBIT-front-image.webp" alt={description} class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">{heading}</h1>
      <p class="text-xl max-w-2xl mx-auto opacity-90">{description}</p>
    </div>
  </div>
  
  <section class="py-24 bg-gray-50 relative overflow-hidden border-b border-gray-100">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-secondary/10 rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-xl shadow-gray-200/50 p-8 md:p-14 border border-gray-100 relative mt-8">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
          <div class="w-20 h-20 bg-white rounded-2xl shadow-lg border border-gray-100 flex items-center justify-center -rotate-3 transition-transform hover:rotate-0 duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
        </div>
        
        <div class="mt-6 prose prose-lg mx-auto text-gray-700 whitespace-pre-line leading-relaxed md:leading-loose text-left md:text-justify">
          <span class="float-left text-6xl md:text-7xl font-heading font-bold text-primary mr-4 mt-1">{body?.trim().charAt(0)}</span>{body?.trim().slice(1)}
        </div>
      </div>
    </div>
  </section>
  
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 text-center mb-12">
      <h2 class="text-3xl font-heading font-bold mb-4">Why Choose Us?</h2>
      <div class="flex justify-center gap-6 flex-wrap mt-8">
        <span class="flex items-center gap-2 bg-gray-50 px-4 py-2 rounded-full font-medium"><span class="text-secondary">✓</span> Fast Booking</span>
        <span class="flex items-center gap-2 bg-gray-50 px-4 py-2 rounded-full font-medium"><span class="text-secondary">✓</span> 5-Star Reviews</span>
        <span class="flex items-center gap-2 bg-gray-50 px-4 py-2 rounded-full font-medium"><span class="text-secondary">✓</span> Prime Location</span>
        <span class="flex items-center gap-2 bg-gray-50 px-4 py-2 rounded-full font-medium"><span class="text-secondary">✓</span> Lowest Price Guarantee</span>
      </div>
    </div>
  </section>

  <section class="py-16 bg-background">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-heading font-bold text-center mb-12">Available Rooms</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {rooms.map(room => (
          <RoomCard {...room} />
        ))}
      </div>
    </div>
  </section>
  
  <section class="py-20 bg-dark text-white text-center">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-heading font-bold mb-6">Ready to Book?</h2>
      <p class="mb-8">Call us directly or book online for immediate confirmation.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/book-now" variant="primary">Book Now</Button>
        <Button href={`tel:${SITE.phone}`} variant="secondary">Call Now</Button>
      </div>
    </div>
  </section>
</Layout>
