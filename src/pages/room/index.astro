---
import Layout from '../../layouts/Layout.astro';
import RoomCard from '../../components/ui/RoomCard.astro';
import { rooms } from '../../data/rooms';
---

<Layout title="Our Rooms & Suites | Hotel Iubit" description="Explore our luxurious rooms and suites. Find the perfect accommodation for your stay.">
  <div class="bg-dark text-white py-20 text-center">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">Our Rooms & Suites</h1>
      <p class="text-xl max-w-2xl mx-auto text-gray-300">Discover comfort and luxury tailored to your needs.</p>
    </div>
  </div>
  
  <section class="py-20 bg-background">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {rooms.map(room => (
          <RoomCard {...room} />
        ))}
      </div>
    </div>
  </section>
</Layout>
