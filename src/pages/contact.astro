---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../utils/seoConfig';
---

<Layout title="Contact Us | Hotel Iubit" description="Get in touch with Hotel Iubit. We are here to help you with your reservations and inquiries.">
  <div class="bg-primary text-white py-20 text-center">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">Contact Us</h1>
      <p class="text-xl max-w-2xl mx-auto text-gray-200">We'd love to hear from you.</p>
    </div>
  </div>
  
  <section class="py-20 bg-background">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
        
        <!-- Contact Info -->
        <div class="bg-dark text-white p-10 md:p-16 flex flex-col justify-center">
          <h2 class="text-3xl font-heading font-bold mb-8">Get In Touch</h2>
          
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="bg-primary/20 p-3 rounded-full text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-lg mb-1">Location</h3>
                <p class="text-gray-400 leading-relaxed">{SITE.address}</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="bg-primary/20 p-3 rounded-full text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-lg mb-1">Phone & WhatsApp</h3>
                <p class="text-gray-400 mb-1"><a href={`tel:${SITE.phone}`} class="hover:text-primary transition-colors">{SITE.phone}</a></p>
                <p class="text-gray-400"><a href={`https://wa.me/${SITE.whatsapp}`} class="hover:text-[#25D366] transition-colors">WhatsApp Us</a></p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="bg-primary/20 p-3 rounded-full text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-lg mb-1">Email</h3>
                <p class="text-gray-400"><a href={`mailto:${SITE.email}`} class="hover:text-primary transition-colors">{SITE.email}</a></p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="p-10 md:p-16">
          <h2 class="text-3xl font-heading font-bold mb-8 text-dark">Send a Message</h2>
          <form id="contact-form" class="space-y-6">
            <input type="hidden" name="access_key" value="f76f3769-59f0-4a81-a763-486a7585e82c" />
            <input type="hidden" name="subject" value="New Contact Message from Hotel Iubit" />
            
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Your Name</label>
              <input id="name" name="name" type="text" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-gray-50 focus:bg-white" required />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
              <input id="email" name="email" type="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-gray-50 focus:bg-white" required />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
              <textarea id="message" name="message" rows="5" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-gray-50 focus:bg-white" required></textarea>
            </div>
            <div>
              <label for="contact-captcha" class="block text-sm font-medium text-gray-700 mb-2">Security Check: What is <span id="contact-num1"></span> + <span id="contact-num2"></span>?</label>
              <input id="contact-captcha" type="number" name="captcha" placeholder="Your answer" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all bg-gray-50 focus:bg-white" required />
            </div>
            <button type="submit" class="w-full bg-primary text-white py-4 rounded-lg font-bold text-lg hover:bg-primary/90 transition-all shadow-md hover:shadow-xl transform hover:-translate-y-1">Send Message</button>
          </form>
        </div>
      </div>
      
      <!-- Map Section -->
      <div class="mt-12 bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100 p-2">
        <iframe 
          src={`https://maps.google.com/maps?q=${encodeURIComponent(SITE.address)}&t=&z=15&ie=UTF8&iwloc=&output=embed`}
          width="100%" 
          height="450" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="rounded-2xl"
          title="Hotel Location"
        ></iframe>
      </div>
    </div>
  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script is:inline>
    const form = document.getElementById('contact-form');
    const submitBtn = form.querySelector('button[type="submit"]');

    // Captcha Logic
    let num1 = Math.floor(Math.random() * 10) + 1;
    let num2 = Math.floor(Math.random() * 10) + 1;
    document.getElementById('contact-num1').innerText = num1;
    document.getElementById('contact-num2').innerText = num2;

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const captchaInput = document.getElementById('contact-captcha').value;
      if (parseInt(captchaInput) !== num1 + num2) {
        Swal.fire({
          title: "Error!",
          text: "Incorrect math answer. Please try again.",
          icon: "error",
          confirmButtonColor: '#ef4444'
        });
        return;
      }
      
      const originalText = submitBtn.innerText;
      submitBtn.innerText = 'Sending...';
      submitBtn.disabled = true;

      const formData = new FormData(form);
      formData.delete('captcha');

      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      })
      .then(async (response) => {
        let json = await response.json();
        if (response.status == 200) {
          Swal.fire({
            title: "Message Sent!",
            text: "Your message has been successfully sent.",
            icon: "success",
            confirmButtonColor: '#3b82f6'
          });
          form.reset();
          
          // Reset Captcha
          num1 = Math.floor(Math.random() * 10) + 1;
          num2 = Math.floor(Math.random() * 10) + 1;
          document.getElementById('contact-num1').innerText = num1;
          document.getElementById('contact-num2').innerText = num2;
          
        } else {
          Swal.fire({
            title: "Error!",
            text: json.message || "Something went wrong.",
            icon: "error",
            confirmButtonColor: '#ef4444'
          });
        }
      })
      .catch(error => {
        Swal.fire({
            title: "Error!",
            text: "Something went wrong! Please try again later.",
            icon: "error",
            confirmButtonColor: '#ef4444'
        });
      })
      .finally(() => {
        submitBtn.innerText = originalText;
        submitBtn.disabled = false;
      });
    });
  </script>
</Layout>
