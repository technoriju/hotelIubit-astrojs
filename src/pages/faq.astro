---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frequently Asked Questions | Hotel Iubit" description="Find answers to common questions about booking, amenities, and policies at Hotel Iubit.">
  <div class="bg-primary text-white py-20 text-center">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">FAQ</h1>
      <p class="text-xl max-w-2xl mx-auto text-gray-200">Frequently Asked Questions</p>
    </div>
  </div>
  
  <section class="py-20 bg-background">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="space-y-6">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <h3 class="text-xl font-bold mb-2">What are the check-in and check-out times?</h3>
          <p class="text-gray-600">Check-in is at 2:00 PM and check-out is at 11:00 AM. Early check-in and late check-out are subject to availability and may incur additional charges.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <h3 class="text-xl font-bold mb-2">Is breakfast included in the room rate?</h3>
          <p class="text-gray-600">No, a complimentary buffet breakfast is included for all guests who book directly through our website.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <h3 class="text-xl font-bold mb-2">Do you have parking facilities?</h3>
          <p class="text-gray-600">Yes, we offer complimentary secure parking for all our guests.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <h3 class="text-xl font-bold mb-2">Are pets allowed?</h3>
          <p class="text-gray-600">We love animals, but currently, we do not allow pets in the hotel to ensure the comfort of all our guests. Service animals are welcome.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <h3 class="text-xl font-bold mb-2">What is your cancellation policy?</h3>
          <p class="text-gray-600">Reservations can be canceled free of charge up to 48 hours before the check-in date. Cancellations made within 48 hours will be charged for the first night.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
