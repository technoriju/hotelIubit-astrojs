---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Services | Hotel Iubit" description="Learn more about Our Services at Hotel Iubit.">
  <div class="bg-primary text-white py-20 text-center">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-heading font-bold">Our Services</h1>
    </div>
  </div>
  
  <section class="py-20 bg-background min-h-[50vh]">
    <div class="container mx-auto px-4 max-w-4xl prose prose-lg">
      <p class="text-xl text-center text-gray-500">Content for Our Services will be updated soon. Please check back later.</p>
    </div>
  </section>
</Layout>
