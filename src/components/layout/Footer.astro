---
import { SITE } from '../../utils/seoConfig';
import { landingPages } from '../../data/seoPages';
const currentYear = new Date().getFullYear();
---
<footer class="bg-dark text-white pt-16 pb-8">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <div>
        <h3 class="text-2xl font-heading font-bold text-secondary mb-4">{SITE.name}</h3>
        <p class="text-gray-400 mb-4">Experience luxury and comfort in the heart of the city.</p>
        <p class="text-gray-300">
          <strong>Address:</strong><br/>
          {SITE.address}
        </p>
      </div>
      
      <div>
        <h4 class="text-xl font-heading font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-gray-400 hover:text-secondary transition-colors">About Us</a></li>
          <li><a href="/room" class="text-gray-400 hover:text-secondary transition-colors">Our Rooms</a></li>
          <li><a href="/services" class="text-gray-400 hover:text-secondary transition-colors">Services</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-secondary transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-xl font-heading font-semibold mb-4">Support</h4>
        <ul class="space-y-2">
          <li><a href="/faq" class="text-gray-400 hover:text-secondary transition-colors">FAQ</a></li>
          <li><a href="/privacy-policy" class="text-gray-400 hover:text-secondary transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-conditions" class="text-gray-400 hover:text-secondary transition-colors">Terms & Conditions</a></li>
          <li><a href="/refund-policy" class="text-gray-400 hover:text-secondary transition-colors">Refund Policy</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-xl font-heading font-semibold mb-4">Contact Us</h4>
        <ul class="space-y-2 text-gray-400">
          <li>Phone: <a href={`tel:${SITE.phone}`} class="hover:text-secondary">{SITE.phone}</a></li>
          <li>WhatsApp: <a href={`https://wa.me/${SITE.whatsapp}`} class="hover:text-secondary">{SITE.whatsapp}</a></li>
          <li>Email: <a href={`mailto:${SITE.email}`} class="hover:text-secondary">{SITE.email}</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-gray-700 pt-8 pb-4 mb-4">
      <h4 class="text-lg font-heading font-semibold mb-4 text-center text-gray-300">Popular Searches</h4>
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3">
        {landingPages.map(page => (
          <a href={`/${page.slug}`} class="text-gray-400 hover:text-secondary text-sm transition-colors">
            {page.title}
          </a>
        ))}
      </div>
    </div>
    
    <div class="border-t border-gray-700 pt-8 flex flex-col md:flex-row justify-between items-center text-gray-500 text-sm">
      <p>&copy; {currentYear} {SITE.name}. All rights reserved.</p>
      <div class="mt-4 md:mt-0 flex space-x-4">
        <!-- Social Icons Here -->
      </div>
    </div>
  </div>
</footer>
