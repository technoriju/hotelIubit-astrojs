---
import Button from './Button.astro';

interface Props {
  title: string;
  image: string;
  price: string;
  occupancy: string;
  size: string;
  facilities: string[];
  slug: string;
}

const { title, image, price, occupancy, size, facilities, slug } = Astro.props;
---

<div class="bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 group border border-gray-100">
  <div class="relative overflow-hidden aspect-[4/3]">
    <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
    <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-4 py-2 rounded-full font-bold text-primary shadow-sm">
      {price}<span class="text-sm font-normal text-gray-600">/day</span>
    </div>
  </div>
  
  <div class="p-6">
    <h3 class="text-2xl font-heading font-bold mb-3 group-hover:text-primary transition-colors">{title}</h3>
    
    <div class="flex items-center gap-4 text-gray-600 text-sm mb-4">
      <div class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        {occupancy}
      </div>
      <div class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
        </svg>
        {size}
      </div>
    </div>
    
    <ul class="flex flex-wrap gap-2 mb-6">
      {facilities.map(facility => (
        <li class="text-xs bg-gray-100 text-gray-700 px-3 py-1 rounded-full">{facility}</li>
      ))}
    </ul>
    
    <div class="flex gap-3">
      <Button href={`/room/${slug}`} variant="outline" className="w-full">Details</Button>
      <Button href="/book-now" variant="primary" className="w-full">Book</Button>
    </div>
  </div>
</div>
